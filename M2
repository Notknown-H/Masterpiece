        return None

    async def search(self, query: str, k: int = 5) -> List[Tuple[str, float]]:
        """Mengembalikan (node_id, distance)."""
        results = []
        if not self.brain.faiss_index or self.brain.faiss_index.ntotal == 0:
            return results

        q_emb = self.embed_text(query)
        if q_emb is None:
            return results

        loop = asyncio.get_running_loop()
