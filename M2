                 50.0, market_cond, None, data.get("price_usd", 0))
            )
        return sig_id

    def log_outcome(self, mint: str, entry_price: float, exit_price: float,
                    duration_min: float, profit_pct: float, result: str, reason: str):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                """UPDATE trade_signals_v2 SET result=?, exit_price=?, profit_percent=?,
                   duration_min=?, reason=? WHERE mint=? AND result IS NULL
                   ORDER BY ts DESC LIMIT 1""",
                (result, exit_price, profit_pct, duration_min, reason, mint)
            )

    def get_expected_value(self, min_trades: int = 50) -> Dict:
        with sqlite3.connect(self.db_path) as conn:
            rows = conn.execute(
                "SELECT profit_percent FROM trade_signals_v2 WHERE result IS NOT NULL AND profit_percent IS NOT NULL ORDER BY ts DESC LIMIT ?",
                (max(min_trades, 200),)
            ).fetchall()
        if len(rows) < min_trades:
            return {"status": "insufficient_data", "count": len(rows)}
        profits = [r[0] for r in rows]
        wins = [p for p in profits if p > 0]
        losses = [p for p in profits if p <= 0]
        win_rate = len(wins) / len(profits)
        avg_win = statistics.mean(wins) if wins else 0
        avg_loss = statistics.mean(losses) if losses else 0
        ev = win_rate * avg_win + (1 - win_rate) * avg_loss
        return {
            "status": "ok", "count": len(profits),
            "win_rate": win_rate, "avg_win_pct": avg_win,
            "avg_loss_pct": avg_loss, "expected_value_pct": ev,
        }

