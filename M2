                CREATE INDEX IF NOT EXISTS idx_knowledge_topic ON knowledge_nodes(topic);
                CREATE VIRTUAL TABLE IF NOT EXISTS knowledge_fts USING fts5(
                    topic, statement, subtopic, tags, content='knowledge_nodes', content_rowid='rowid'
                );
                CREATE TABLE IF NOT EXISTS knowledge_ledger (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    node_id TEXT,
