        if self.session:
            await self.session.close()
        self.active = False

    async def _send_task(self, prompt: str, priority: int = 5):
        if not self.active or not self.session:
            return
        try:
            async with self.session.post(
                f"{self.api_url}/agent/task",
                json={"prompt": prompt, "priority": priority},
                timeout=aiohttp.ClientTimeout(total=30)
            ) as r:
                if r.status == 200:
                    log.info(f"Claw task sent: {prompt[:50]}")
        except Exception as e:
            log.error(f"ClawController task error: {e}")

