    def _init_db(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.executescript("""
                CREATE TABLE IF NOT EXISTS knowledge_nodes (
                    id TEXT PRIMARY KEY,
                    topic TEXT,
                    subtopic TEXT,
                    statement TEXT,
                    epistemic_type TEXT,
                    confidence_score REAL,
                    update_policy TEXT,
