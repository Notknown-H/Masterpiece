# 18. UHEE ENGINE (Unified Hypothesis Evolutionary Engine)
# =============================================================================
class HypothesisType(Enum):
    CORRELATION = "correlation"
    THRESHOLD = "threshold"
    PATTERN = "pattern"
    CAUSAL = "causal"

class HypothesisStatus(Enum):
    CANDIDATE = "candidate"
    VALIDATED = "validated"
    REJECTED = "rejected"
    ACTIVE = "active"

@dataclass
class Hypothesis:
    id: str
    type: HypothesisType
    antecedent: Dict   # {"feature": ..., "op": ..., "value": ...}
    consequent: Dict   # {"feature": ..., "direction": ..., "magnitude": ...}
    confidence: float = 0.0
    support: float = 0.0
    fitness: float = 0.0
    status: HypothesisStatus = HypothesisStatus.CANDIDATE
    generation: int = 0
    validated_at: Optional[float] = None
    metadata: Dict = field(default_factory=dict)

class UHEEEngine:
    """Evolusi hipotesis dari data numerik (trading dan scraped)."""

    def __init__(self, population_size: int = 30, mutation_rate: float = 0.2, elite_size: int = 5):
        self.population_size = population_size
        self.mutation_rate = mutation_rate
        self.elite_size = elite_size
        self.cycle_count = 0
        self.population: List[Hypothesis] = []
        self.history: List[Dict] = []
        self._backtest_window = 20
        self._backtest_step = 5

    def _generate_initial_population(self, df: pd.DataFrame) -> List[Hypothesis]:
        numeric_cols = list(df.select_dtypes(include=[np.number]).columns)
        if len(numeric_cols) < 2:
            return []
        hypotheses = []
        for i in range(self.population_size):
            ant_feat = random.choice(numeric_cols)
            cons_feat = random.choice(numeric_cols)
            col = df[ant_feat].dropna()
            if col.empty:
                continue
            threshold = float(col.quantile(random.choice([0.25, 0.5, 0.75])))
            hyp = Hypothesis(
                id=f"hyp_{self.cycle_count}_{i}_{int(time.time())}",
                type=random.choice(list(HypothesisType)),
                antecedent={"feature": ant_feat, "op": random.choice(["gt", "lt", "gte", "lte"]), "value": threshold},
                consequent={"feature": cons_feat, "direction": random.choice(["up", "down"]), "magnitude": random.uniform(0.01, 0.1)},
                generation=self.cycle_count,
            )
            hypotheses.append(hyp)
        return hypotheses

    def _evaluate_hypothesis(self, hyp: Hypothesis, df: pd.DataFrame) -> Hypothesis:
        """Backtest hipotesis pada data."""
        df = df.select_dtypes(include=[np.number]).fillna(method="ffill")
        if len(df) < self._backtest_window * 2:
            hyp.fitness = 0.0
            return hyp

        ant_feat = hyp.antecedent.get("feature")
        op = hyp.antecedent.get("op", "gt")
        val = hyp.antecedent.get("value", 0)
        cons_feat = hyp.consequent.get("feature")
        direction = hyp.consequent.get("direction", "up")
        magnitude = hyp.consequent.get("magnitude", 0.01)

        ops = {
            "gt": lambda x, y: x > y, "lt": lambda x, y: x < y,
            "gte": lambda x, y: x >= y, "lte": lambda x, y: x <= y,
            "eq": lambda x, y: abs(x - y) < y * 0.01,
        }
        compare = ops.get(op, ops["gt"])

        fires = 0
        hits = 0
        n = len(df)
        for i in range(0, n - self._backtest_window * 2, self._backtest_step):
            window = df.iloc[i : i + self._backtest_window]
            next_w = df.iloc[i + self._backtest_window : i + self._backtest_window * 2]
            if ant_feat in window.columns:
                if compare(window[ant_feat].iloc[-1], val):
                    fires += 1
                    if cons_feat in next_w.columns and len(next_w) >= 2:
                        pct = (next_w[cons_feat].iloc[-1] - next_w[cons_feat].iloc[0]) / (next_w[cons_feat].iloc[0] or 1)
                        if (direction == "up" and pct >= magnitude) or (direction == "down" and pct <= -magnitude):
                            hits += 1

        if fires == 0:
            hyp.confidence = 0.0
            hyp.support = 0.0
            hyp.fitness = 0.0
        else:
            hyp.confidence = hits / fires
            hyp.support = fires / max(1, (n - self._backtest_window * 2) / self._backtest_step)
            if hyp.confidence + hyp.support > 0:
                hyp.fitness = (2 * hyp.confidence * hyp.support) / (hyp.confidence + hyp.support)
        return hyp

    def _mutate(self, hyp: Hypothesis) -> Hypothesis:
        new = copy.deepcopy(hyp)
        new.id = f"mutant_{int(time.time())}_{random.randint(0, 9999)}"
        if random.random() < self.mutation_rate:
            new.antecedent["value"] *= random.uniform(0.8, 1.2)
        if random.random() < self.mutation_rate:
            new.consequent["magnitude"] *= random.uniform(0.8, 1.2)
        if random.random() < self.mutation_rate:
            new.consequent["direction"] = "up" if new.consequent["direction"] == "down" else "down"
        new.generation += 1
        return new

    def run_cycle(self, data: pd.DataFrame, source_name: str = "unknown") -> Dict:
        """Satu siklus evolusi."""
        if data.empty or len(data) < 10:
            return {"status": "error", "error": "insufficient_data", "top_hypotheses": []}

        # Inisialisasi populasi jika kosong
        if not self.population:
            self.population = self._generate_initial_population(data)
        else:
            elites = sorted(self.population, key=lambda h: h.fitness, reverse=True)[:self.elite_size]
            new_pop = list(elites)
            while len(new_pop) < self.population_size:
                parent = random.choice(elites)
                new_pop.append(self._mutate(parent))
            self.population = new_pop

        # Evaluasi
        for hyp in self.population:
            self._evaluate_hypothesis(hyp, data)

        self.population.sort(key=lambda h: h.fitness, reverse=True)
        top = self.population[:5]

        # Promosikan hipotesis valid
        for hyp in top:
            if hyp.fitness >= 0.6:
                hyp.status = HypothesisStatus.VALIDATED
                hyp.validated_at = time.time()

        stats = {
            "best": top[0].fitness if top else 0,
            "mean": statistics.mean(h.fitness for h in self.population) if self.population else 0,
            "worst": self.population[-1].fitness if self.population else 0,
        }
        self.cycle_count += 1
        result = {
            "status": "ok",
            "cycle": self.cycle_count,
            "top_hypotheses": [asdict(h) for h in top],
            "stats": stats,
            "source": source_name,
        }
        self.history.append(result)
        return result

uhee_engine = UHEEEngine()

