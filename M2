                    timestamp REAL,
                    details TEXT
                );
            """)

    def _load_faiss(self):
        index_path = "knowledge_vectors.faiss"
        if os.path.exists(index_path):
            self.faiss_index = faiss.read_index(index_path)
            ids_path = index_path + ".ids"
            if os.path.exists(ids_path):
                with open(ids_path, "rb") as f:
                    data = pickle.load(f)
                    self.id_map = data.get("id_map", {})
                    self.reverse_map = data.get("reverse_map", {})
        else:
            self.faiss_index = faiss.IndexFlatL2(self.vector_dim)

    def _save_faiss(self):
        faiss.write_index(self.faiss_index, "knowledge_vectors.faiss")
        with open("knowledge_vectors.faiss.ids", "wb") as f:
            pickle.dump({"id_map": self.id_map, "reverse_map": self.reverse_map}, f)

    def _load_json_brain(self):
        # Migrasi otomatis jika ada file lama
        if os.path.exists(LOCAL_BRAIN_FILE):
            try:
                with open(LOCAL_BRAIN_FILE, "r") as f:
                    old_nodes = json.load(f)
                if isinstance(old_nodes, list):
                    self.add_knowledge(old_nodes)
                os.remove(LOCAL_BRAIN_FILE)
            except Exception:
                pass

    def add_knowledge(self, nodes: List[dict]) -> int:
        """Tambah/update node ke SQLite dan FAISS."""
        added = 0
        for node in nodes:
            if not isinstance(node, dict) or not node.get("statement"):
                continue
            node_id = node.get("id", f"node_{uuid.uuid4()}")
            # Validasi ringan
            ep = node.get("epistemic_type", "fact")
            if ep not in {"fact","heuristic","decision_rule","failure_mode","causal","synthesis"}:
                ep = "fact"
            # Embedding
            emb = None
            if self.embedder:
                emb = self.embedder.encode(node["statement"])
            # Simpan ke SQLite
            with sqlite3.connect(self.db_path) as conn:
                conn.execute("""
                    INSERT OR REPLACE INTO knowledge_nodes
                    (id, topic, subtopic, statement, epistemic_type, confidence_score,
                     update_policy, utility_class, tags, relations, faiss_id,
                     embedding_blob, created_at, updated_at)
                    VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)
                """, (
                    node_id,
                    node.get("topic", ""),
                    node.get("subtopic", ""),
                    node["statement"][:500],
                    ep,
                    node.get("confidence_score", 0.7),
                    node.get("update_policy", "dynamic"),
                    node.get("utility_class", "inference_only"),
                    json.dumps(node.get("tags", [])),
                    json.dumps(node.get("relations", [])),
                    -1,  # sementara
                    emb.tobytes() if emb is not None else None,
                    time.time(), time.time()
                ))
            # Tambahkan ke FAISS
            if emb is not None and self.faiss_index is not None:
                self.faiss_index.add(emb.reshape(1, -1))
                faiss_id = self.faiss_index.ntotal - 1
                self.id_map[faiss_id] = node_id
                self.reverse_map[node_id] = faiss_id
                with sqlite3.connect(self.db_path) as conn:
                    conn.execute("UPDATE knowledge_nodes SET faiss_id = ? WHERE id = ?", (faiss_id, node_id))
            added += 1
        if added:
            self._save_faiss()
        return added

    def query(self, query_text: str, limit: int = 5, epistemic_filter: List[str] = None) -> List[dict]:
        """Hybrid search: FAISS + FTS."""
        results = []
        # FAISS search
        if self.embedder and self.faiss_index and self.faiss_index.ntotal > 0:
            q_emb = self.embedder.encode(query_text).reshape(1, -1)
            distances, indices = self.faiss_index.search(q_emb, limit)
            for dist, idx in zip(distances[0], indices[0]):
                if idx >= 0 and idx in self.id_map:
                    node_id = self.id_map[idx]
                    node = self._get_node_by_id(node_id)
                    if node:
                        if not epistemic_filter or node["epistemic_type"] in epistemic_filter:
                            node["_score"] = float(dist)
                            results.append(node)
        # FTS fallback
        if len(results) < limit:
            with sqlite3.connect(self.db_path) as conn:
                try:
                    conn.execute("INSERT INTO knowledge_fts(knowledge_fts) VALUES('optimize')")
                except:
                    pass
                cursor = conn.execute("""
                    SELECT n.* FROM knowledge_nodes n
                    JOIN knowledge_fts f ON n.rowid = f.rowid
                    WHERE knowledge_fts MATCH ?
                    ORDER BY rank LIMIT ?
                """, (query_text, limit))
                for row in cursor:
                    node = self._row_to_dict(row)
                    if node and node["id"] not in {n["id"] for n in results}:
                        if not epistemic_filter or node["epistemic_type"] in epistemic_filter:
                            results.append(node)
        return results[:limit]

    def _get_node_by_id(self, node_id: str) -> Optional[dict]:
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute("SELECT * FROM knowledge_nodes WHERE id = ?", (node_id,))
            row = cursor.fetchone()
            return self._row_to_dict(row) if row else None

    def _row_to_dict(self, row) -> dict:
        cols = ["id","topic","subtopic","statement","epistemic_type","confidence_score",
                "update_policy","utility_class","tags","relations","faiss_id",
                "embedding_blob","created_at","updated_at","access_count"]
        d = dict(zip(cols, row))
        d["tags"] = json.loads(d["tags"]) if d["tags"] else []
        d["relations"] = json.loads(d["relations"]) if d["relations"] else []
        return d

    def answer_from_brain(self, query: str) -> Optional[str]:
        nodes = self.query(query, limit=5)
        if not nodes:
            return None
        ans = "🧠 [Unified Knowledge]\n\n"
        for node in nodes:
            ans += f"- [{node['epistemic_type']}] {node['statement'][:200]}\n"
        return ans

