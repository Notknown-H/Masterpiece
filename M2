# 8. QUANTUM‑SPARSE NEURAL DNA (UNIFIED, TORCH PRIORITY)
# =============================================================================
class QuantumSparseDNA:
    """DNA engine yang berjalan di Torch jika tersedia, fallback ke NumPy."""

    def __init__(self, dna_size=256, latent_dim=128):
        self.use_torch = TORCH_AVAILABLE
        if self.use_torch:
            self.dna = nn.Parameter(torch.randn(dna_size, latent_dim, dtype=torch.float16) * 0.01)
            self.alpha = nn.Parameter(torch.ones(1, dtype=torch.float16))
            self.beta = nn.Parameter(torch.zeros(1, dtype=torch.float16))
        else:
            self.dna = np.random.randn(dna_size, latent_dim).astype(np.float16) * 0.01
            self.alpha = 1.0
            self.beta = 0.0
        self.dna_size = dna_size
        self.latent_dim = latent_dim
        self.sparsity = 0.01
        self.cache = OrderedDict()
        self.cache_limit = 100
        self._lock = threading.RLock()

    def forward(self, input_vector: Union[np.ndarray, torch.Tensor], layer_id: int = 0):
        """Menerima input 1D atau 2D, mengembalikan (weight_matrix, gene_indices)."""
        if self.use_torch:
            return self._forward_torch(input_vector, layer_id)
        else:
            return self._forward_np(input_vector, layer_id)

    def _forward_np(self, x: np.ndarray, layer_id: int):
        # Normalisasi input
        if x.ndim == 1:
            x = x.reshape(1, -1)
        if x.shape[1] != self.latent_dim:
            if x.shape[1] > self.latent_dim:
                x = x[:, :self.latent_dim]
            else:
                pad = np.zeros((x.shape[0], self.latent_dim - x.shape[1]), dtype=np.float16)
                x = np.hstack([x, pad])
        cond = x.mean(axis=0).astype(np.float16)
        cache_key = f"layer_{layer_id}_{hash(cond.tobytes()) % 10000}"
        with self._lock:
            if cache_key in self.cache:
                self.cache.move_to_end(cache_key)
                return self.cache[cache_key], np.array([])

        scores = cond @ self.dna.T
        k = max(1, int(self.dna_size * self.sparsity))
        indices = np.argpartition(scores, -k)[-k:]
        active = self.dna[indices]
        a = active.mean(axis=0)
        b = active[::-1].mean(axis=0)
        w = np.outer(a, b)
        threshold = np.percentile(np.abs(w), 90)
        w[np.abs(w) < threshold] = 0
        w = np.round(w * 3) / 3
        w = w / (np.linalg.norm(w) + 1e-8)
        w = self.alpha * w + self.beta
        with self._lock:
            self.cache[cache_key] = w
            if len(self.cache) > self.cache_limit:
                self.cache.popitem(last=False)
        return w.astype(np.float16), indices

    def _forward_torch(self, x, layer_id: int):
        if isinstance(x, np.ndarray):
            x = torch.from_numpy(x).to(device)
        if x.dim() == 1:
            x = x.unsqueeze(0)
        cond = x.mean(dim=0)
        cache_key = f"layer_{layer_id}_{hash(cond.cpu().numpy().tobytes()) % 10000}"
        with self._lock:
            if cache_key in self.cache:
                self.cache.move_to_end(cache_key)
                return self.cache[cache_key], torch.tensor([])

        scores = cond @ self.dna.T
        k = max(1, int(self.dna_size * self.sparsity))
        _, indices = torch.topk(scores, k)
        active = self.dna[indices]
        a = active.mean(dim=0)
        b = active.flip(0).mean(dim=0)
        w = torch.outer(a, b)
        threshold = torch.quantile(torch.abs(w), 0.9)
        w = torch.where(torch.abs(w) < threshold, torch.zeros_like(w), w)
        w = torch.round(w * 3) / 3
        w = w / (torch.norm(w) + 1e-8)
        w = self.alpha * w + self.beta
        with self._lock:
            self.cache[cache_key] = w
            if len(self.cache) > self.cache_limit:
                self.cache.popitem(last=False)
        return w, indices

    def clear_cache(self):
        with self._lock:
            self.cache.clear()

