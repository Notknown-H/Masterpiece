        if not self.enabled:
            log.info("ClawController disabled")
            return
        self.session = aiohttp.ClientSession()
        try:
            async with self.session.get(f"{self.api_url}/health", timeout=aiohttp.ClientTimeout(total=5)) as r:
                self.active = (r.status == 200)
                log.info(f"ClawController: {'connected' if self.active else 'unreachable'}")
        except Exception as e:
            self.active = False
            log.warning(f"ClawController health check failed: {e}")

