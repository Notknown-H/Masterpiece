class ExitManager:
    def __init__(self, trailing_pct: float = 3.0, dynamic_tp_pct: float = 20.0, dynamic_sl_pct: float = -12.0):
        self.trailing_pct = trailing_pct
        self.dynamic_tp_pct = dynamic_tp_pct
        self.dynamic_sl_pct = dynamic_sl_pct
        self._positions: Dict[str, Dict] = {}

    def register_position(self, mint: str, entry_price: float, volume: float):
        self._positions[mint] = {
            "entry_price": entry_price,
            "peak_price": entry_price,
            "peak_volume": volume,
        }

    def update_price(self, mint: str, current_price: float):
        pos = self._positions.get(mint)
        if pos and current_price > pos["peak_price"]:
            pos["peak_price"] = current_price

    def should_exit(self, mint: str, current_price: float, flow_score: float, buy_ratio: float, current_volume: float = 0) -> Tuple[bool, str]:
        pos = self._positions.get(mint)
        if not pos:
            return False, ""
        entry = pos["entry_price"]
        if entry <= 0:
            return False, ""
        profit_pct = (current_price - entry) / entry * 100
        # 1. Take Profit
        if profit_pct >= self.dynamic_tp_pct:
            return True, f"take_profit({profit_pct:.1f}%)"
        # 2. Stop Loss
        if profit_pct <= self.dynamic_sl_pct:
            return True, f"stop_loss({profit_pct:.1f}%)"
        # 3. Trailing Stop
        peak = pos["peak_price"]
        if peak > entry:
            drawdown = (current_price - peak) / peak * 100
            if drawdown <= -self.trailing_pct:
                return True, f"trailing_stop(drawdown={drawdown:.1f}%)"
        # 4. Flow score collapse
        if flow_score < 25 and profit_pct > 3:
            return True, f"flow_exit(score={flow_score:.0f})"
        # 5. Buy pressure collapse
        if buy_ratio < 0.3 and profit_pct > 3:
            return True, f"buy_pressure_collapse({buy_ratio:.2f})"
        return False, ""

    def remove_position(self, mint: str):
        self._positions.pop(mint, None)

