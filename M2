    await event_bus.publish("system_started", {
        "timestamp": time.time(),
        "version": "5.0-Integrated",
        "brain_nodes": unified_brain.get_stats()["total_nodes"],
        "dna_size": dna.dna_size,
        "dna_latent_dim": dna.latent_dim,
