class EventBus:
    def __init__(self):
        self._handlers: Dict[str, List[Callable]] = defaultdict(list)
        self._history: deque = deque(maxlen=5000)
        self._queue: asyncio.Queue = asyncio.Queue()
        self._running = True

    async def start(self):
        """Main loop processing async events."""
        while self._running:
            packet = await self._queue.get()
            await self._dispatch(packet)

    def subscribe(self, event: str, handler: Callable):
        self._handlers[event].append(handler)

    async def publish(self, event: str, data: dict):
        packet = {"event": event, "data": data, "ts": time.time()}
        self._history.append(packet)
        await self._queue.put(packet)

    async def _dispatch(self, packet: dict):
        event = packet["event"]
        data = packet["data"]
        for handler in self._handlers.get(event, []):
            try:
                result = handler(data)
                if asyncio.iscoroutine(result):
                    await result
            except Exception as e:
                log.error(f"EventBus error [{event}]: {e}")

    def get_history(self, event: str = None, limit: int = 50) -> List[dict]:
        h = list(self._history)
        if event:
            h = [x for x in h if x["event"] == event]
        return h[-limit:]

    async def stop(self):
        self._running = False

event_bus = EventBus()

