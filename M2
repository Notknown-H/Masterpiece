    async def _monitor_position(self, mint: str, chat_id: int):
        """Monitor satu posisi hingga exit."""
        while mint in self.positions and self.active and not kill_check():
            await asyncio.sleep(5)
            try:
                data = await get_token_data(mint)
                if not data:
                    continue
                current_price = data.get("price_usd", 0)
                if current_price == 0:
                    continue

                await self.flow_tracker.update(mint)
                flow = self.flow_tracker.analyze(mint)

                self.exit_manager.update_price(mint, current_price)

                pos = self.positions[mint]
                entry_price = pos.get("entry_price", current_price)
                if not entry_price or entry_price == 0:
                    entry_price = current_price
                    pos["entry_price"] = current_price
                profit_pct = (current_price - entry_price) / entry_price * 100

                # Cek exit
                should_exit, reason = self.exit_manager.should_exit(
                    mint, current_price, flow["flow_score"], flow["buy_ratio"]
                )

                if should_exit:
                    duration = (time.time() - pos["ts"]) / 60
                    result = "WIN" if profit_pct > 2 else "LOSS" if profit_pct < -2 else "BREAK_EVEN"

                    # Log
                    self.trade_logger.log_outcome(mint, entry_price, current_price, duration, profit_pct, result, reason)
                    self.validator.record_outcome(profit_pct)
                    if profit_pct < 0:
                        self.risk_mgr.record_loss(profit_pct)

                    # Sell
                    await self.execute_sell(mint, pos["buy_sol"], chat_id)

                    # Publish event
                    await event_bus.publish("trade_closed", {
                        "mint": mint, "entry_price": entry_price, "exit_price": current_price,
                        "profit_pct": profit_pct, "duration_min": duration, "reason": reason,
                        "result": result, "sol_amount": pos["buy_sol"],
                    })

                    # Cleanup
                    del self.positions[mint]
                    self.exit_manager.remove_position(mint)
                    self.smart_planner.reset_entry_count(mint)
                    if mint in self._monitor_tasks:
                        self._monitor_tasks.pop(mint)
                    break

            except Exception as e:
                log.error(f"monitor_position error [{mint[:12]}]: {e}")
                await asyncio.sleep(10)

