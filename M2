                    return signals
                data = await resp.json()
                pairs = data.get("pairs", [])
    except Exception as e:
        log.debug(f"scan_meme_coins error: {e}")
        return signals

    for pair in pairs[:50]:
        try:
            mc = float(pair.get("fdv") or pair.get("marketCap") or 0)
            vol = float(pair.get("volume", {}).get("h24", 0))
            price = float(pair.get("priceUsd") or 0)
            mint = pair.get("baseToken", {}).get("address", "")
            name = pair.get("baseToken", {}).get("name", "")
            symbol = pair.get("baseToken", {}).get("symbol", "")
            txns = pair.get("txns", {}).get("h24", {})
            buys = txns.get("buys", 0)
            sells = txns.get("sells", 0)

            if not mint or mc > 10_000_000 or mc < 5_000:
                continue

            # Simple score
            score = 0
            if 10_000 <= mc <= 100_000:
                score += 30
            elif 100_000 <= mc <= 1_000_000:
                score += 40
            elif 1_000_000 <= mc <= 5_000_000:
                score += 25
            ratio = vol / mc if mc > 0 else 0
            if ratio >= 5:
                score += 30
            elif ratio >= 2:
                score += 20
            elif ratio >= 0.5:
                score += 10

            buy_ratio = buys / (buys + sells) if (buys + sells) > 0 else 0.5
            if buy_ratio > 0.6:
                score += 10

            if score >= 40:
                signals.append({
                    "mint": mint, "name": name, "symbol": symbol, "score": score,
                    "market_cap": mc, "volume_h24": vol, "price_usd": price,
                    "buy_ratio": buy_ratio, "buys": buys, "sells": sells,
                })
        except Exception:
            continue

    signals.sort(key=lambda x: x["score"], reverse=True)
    return signals[:20]

