                    unified_brain.add_knowledge(old_data)
                elif isinstance(old_data, dict) and "id" in old_data:
                    unified_brain.add_knowledge([old_data])
                os.remove(fpath)
                log.info(f"Migrated legacy brain file: {fpath}")
            except Exception as e:
                log.warning(f"Migration failed [{fpath}]: {e}")

    log.info(f"✅ Knowledge migrated — {unified_brain.get_stats()['total_nodes']} nodes")

    # Step 3: Initialize DNA, Memory Manager, Unified Meta-Governor
    dna = QuantumSparseDNA(dna_size=256, latent_dim=128)
    mm = ThreeLevelMemoryManager(l1_mb=20, l2_mb=100)
