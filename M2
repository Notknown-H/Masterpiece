class EnhancedRiskManager:
    def __init__(self, max_open_positions: int = 3, daily_loss_limit: float = -8.0, consecutive_loss_limit: int = 5):
        self.max_open_positions = max_open_positions
        self.daily_loss_limit = daily_loss_limit
        self.consecutive_loss_limit = consecutive_loss_limit
        self._daily_loss_pct = 0.0
        self._consecutive_losses = 0
        self._kill_switch = False

    def record_loss(self, loss_pct: float):
        if loss_pct >= 0:
            self._consecutive_losses = 0
            return
        self._consecutive_losses += 1
        self._daily_loss_pct += loss_pct

    def is_kill_switch(self) -> bool:
        if self._kill_switch:
            return True
        if self._daily_loss_pct <= self.daily_loss_limit:
            self._kill_switch = True
            log.warning(f"Risk kill: daily loss {self._daily_loss_pct:.1f}%")
            return True
        if self._consecutive_losses >= self.consecutive_loss_limit:
            self._kill_switch = True
            log.warning(f"Risk kill: {self._consecutive_losses} consecutive losses")
            return True
        return False

    def can_open_position(self, current_positions: int) -> bool:
        return not self.is_kill_switch() and current_positions < self.max_open_positions

    def reset_daily(self):
        self._daily_loss_pct = 0.0
        self._consecutive_losses = 0
        self._kill_switch = False

