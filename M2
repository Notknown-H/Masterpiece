class SplitEntryManager:
    def __init__(self, split_ratio: float = 0.7, max_entries: int = 3):
        self.split_ratio = split_ratio
        self.max_entries = max_entries
        self._positions: Dict[str, Dict] = {}

    def first_entry(self, mint: str, total_amount: float, entry_price: float) -> float:
        amount = total_amount * self.split_ratio
        self._positions[mint] = {
            "total": total_amount, "entries": 1,
            "entry_price": entry_price,
            "remaining": total_amount * (1 - self.split_ratio)
        }
        return amount

    def can_add(self, mint: str) -> bool:
        pos = self._positions.get(mint, {})
        return pos.get("entries", 0) < self.max_entries and pos.get("remaining", 0) > 0

    async def check_second_entry(self, mint: str, current_price: float) -> float:
        pos = self._positions.get(mint, {})
        if not pos or not self.can_add(mint):
            return 0.0
        entry_price = pos.get("entry_price", current_price)
        if entry_price > 0 and (current_price - entry_price) / entry_price * 100 >= 1.0:
            remaining = pos.get("remaining", 0)
            pos["entries"] += 1
            pos["remaining"] = 0
            return remaining
        return 0.0

    def remove(self, mint: str):
        self._positions.pop(mint, None)

class FlowTracker:
    """Mendeteksi spike volume dan buy/sell pressure."""
    def __init__(self, window: int = 5):
        self.window = window
        self._data: Dict[str, Dict] = defaultdict(lambda: {"volumes": deque(maxlen=20), "buys": deque(maxlen=20), "sells": deque(maxlen=20)})

    async def update(self, mint: str):
        data = await get_token_data(mint)
        if data:
            d = self._data[mint]
            d["volumes"].append(data.get("volume_h24", 0))
            d["buys"].append(data.get("txns_h24_buys", 0))
            d["sells"].append(data.get("txns_h24_sells", 0))

    def analyze(self, mint: str) -> Dict:
        d = self._data.get(mint, {"volumes": deque(), "buys": deque(), "sells": deque()})
        vols = list(d["volumes"])
        buys = list(d["buys"])
        sells = list(d["sells"])
        if not vols:
            return {"flow_score": 50, "buy_ratio": 0.5, "vol_spike": 1.0, "trend": "neutral"}

        vol_spike = vols[-1] / vols[-2] if len(vols) >= 2 and vols[-2] > 0 else 1.0
        total_buys = sum(buys[-self.window:]) if buys else 0
        total_sells = sum(sells[-self.window:]) if sells else 0
        buy_ratio = total_buys / (total_buys + total_sells) if (total_buys + total_sells) > 0 else 0.5

        score = 50
        if vol_spike >= 1.5: score += 20
        if buy_ratio > 0.65: score += 20
        elif buy_ratio < 0.35: score -= 20
        trend = "bullish" if score > 65 else "bearish" if score < 35 else "neutral"
        return {"flow_score": max(0, min(100, score)), "buy_ratio": buy_ratio, "vol_spike": vol_spike, "trend": trend}

class SmartMoneyDetector:
    def __init__(self, large_tx_threshold_usd: float = 10_000):
        self.threshold = large_tx_threshold_usd

    async def analyze(self, mint: str, data: Dict) -> Dict:
        result = {"signal": "neutral", "confidence": 0.0, "whale_txns": 0}
        vol = data.get("volume_h24", 0)
        mc = data.get("market_cap", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)
        if vol <= 0 or mc <= 0:
            return result
        vol_ratio = vol / mc
        total_txns = buys + sells
        if total_txns > 0:
            avg_tx = vol / total_txns
            if avg_tx > self.threshold:
                result["whale_txns"] = int(total_txns * (avg_tx / self.threshold))
        buy_ratio = buys / total_txns if total_txns > 0 else 0.5
        if result["whale_txns"] > 0 and buy_ratio > 0.6:
            result["signal"] = "whale_accumulation"
            result["confidence"] = min(0.9, buy_ratio * vol_ratio / 10)
        elif result["whale_txns"] > 0 and buy_ratio < 0.4:
            result["signal"] = "whale_dumping"
            result["confidence"] = min(0.9, (1 - buy_ratio) * vol_ratio / 10)
        return result

class CooldownTracker:
    def __init__(self, cooldown_minutes: int = 15):
        self.cooldown = cooldown_minutes * 60
        self._last: Dict[str, float] = {}

    def can_check(self, mint: str) -> bool:
        now = time.time()
        if now - self._last.get(mint, 0) > self.cooldown:
            self._last[mint] = now
            return True
        return False

    def reset(self, mint: str):
        self._last.pop(mint, None)

