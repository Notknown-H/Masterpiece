class AdaptiveScorer:
    """Skor adaptif berdasarkan histori trading global."""

    def __init__(self, lookback: int = 50):
        self.history: deque = deque(maxlen=lookback)
        self.win_rate = 0.5
        self.avg_profit = 0.0
        self.market_baseline: Dict = {}
        event_bus.subscribe("trade_closed", self.on_trade_closed)

    async def on_trade_closed(self, data: dict):
        profit = data.get("profit_pct", 0)
        ts = time.time()
        self.history.append({"profit_pct": profit, "ts": ts})
        if self.history:
            wins = sum(1 for h in self.history if h["profit_pct"] > 0)
            self.win_rate = wins / len(self.history)
            self.avg_profit = statistics.mean(h["profit_pct"] for h in self.history)
        # Update baseline dari data trade
        for key in ("volume_h24", "market_cap", "price_change_h24"):
            val = data.get(key)
            if val is not None:
                self.market_baseline[key] = val   # simplifying: latest value as baseline

    def score(self, data: Dict) -> int:
        base = self._calculate_base(data)
        # Modulation based on overall win rate
        if self.win_rate < 0.4:
            base = int(base * 0.85)
        elif self.win_rate > 0.65:
            base = int(base * 1.05)
        return max(0, min(100, base))

    def _calculate_base(self, data: Dict) -> int:
        score = 0
        mc = data.get("market_cap", 0)
        vol = data.get("volume_h24", 0)
        change = data.get("price_change_h24", 0)
        liquidity = data.get("liquidity_usd", 0)
        buys = data.get("txns_h24_buys", 0)
        sells = data.get("txns_h24_sells", 0)

        if 50_000 <= mc <= 500_000: score += 25
        elif 500_000 <= mc <= 2_000_000: score += 20
        elif mc > 2_000_000: score += 10

        if mc > 0:
            vol_ratio = vol / mc
            if vol_ratio >= 3: score += 25
            elif vol_ratio >= 1: score += 15
            elif vol_ratio >= 0.3: score += 5

        if 10 <= change <= 100: score += 20
        elif change > 100: score += 10
        elif change < -20: score -= 15

        total_txns = buys + sells
        if total_txns > 0:
            buy_ratio = buys / total_txns
            if buy_ratio > 0.65: score += 15
            elif buy_ratio > 0.55: score += 8

        if liquidity >= 50_000: score += 15
        elif liquidity >= 10_000: score += 8

        return score

