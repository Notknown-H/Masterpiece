class CodeGenerator:
    """Menghasilkan dan mengelola strategi trading dari hipotesis UHEE."""

    def __init__(self, strategies_dir: Path = Path("strategies"), backup_dir: Path = Path("backups")):
        self.strategies_dir = strategies_dir
        self.backup_dir = backup_dir
        self.strategies_dir.mkdir(exist_ok=True)
        self.backup_dir.mkdir(exist_ok=True)
        self.version = 0
        self.loaded_strategies: Dict[str, Any] = {}
        self._lock = asyncio.Lock()

    def _backup_main(self):
        """Backup file utama sebelum modifikasi."""
        main_file = Path(__file__).resolve()
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        dst = self.backup_dir / f"backup_{ts}.py"
        try:
            shutil.copy2(main_file, dst)
            log.info(f"Backup: {dst}")
        except Exception as e:
            log.warning(f"Backup failed: {e}")

    def validate(self, code: str) -> bool:
        """Validasi keamanan dan sintaks kode."""
        try:
            ast.parse(code)
        except SyntaxError as e:
            log.warning(f"CodeGen syntax error: {e}")
            return False

        dangerous = ["os.system", "subprocess.call", "subprocess.run",
                     "eval(", "exec(", "__import__", "shutil.rmtree", "import os", "rm -rf"]
        code_lower = code.lower()
        for d in dangerous:
            if d.lower() in code_lower:
                log.warning(f"CodeGen rejected: dangerous '{d}'")
                return False

        if "class " not in code and "def " not in code:
            log.warning("CodeGen rejected: no class/function")
            return False
        return True

    def generate_from_hypothesis(self, hypothesis: dict, strategy_name: str = None) -> Optional[str]:
        """Generate kode strategi dari hipotesis UHEE."""
        if not strategy_name:
            strategy_name = f"Strategy_{hypothesis.get('id', 'gen')[:20].replace('-', '_')}"
        strategy_name = re.sub(r'[^a-zA-Z0-9_]', '_', strategy_name)

        ant = hypothesis.get("antecedent", {})
        cons = hypothesis.get("consequent", {})
        ant_feat = ant.get("feature", "price_usd")
        ant_op = ant.get("op", "gt")
        ant_val = ant.get("value", 0)
        cons_dir = cons.get("direction", "up")

        op_map = {"gt": ">", "lt": "<", "gte": ">=", "lte": "<="}
        op_str = op_map.get(ant_op, ">")

        code = f"""
class {strategy_name}:
    \"\"\"Auto-generated strategy. Hypothesis: {hypothesis.get('id', '?')} Fitness: {hypothesis.get('fitness', 0):.3f}\"\"\"
    def __init__(self):
        self.threshold = {ant_val}
        self.feature = "{ant_feat}"
        self.expected_direction = "{cons_dir}"

    def should_buy(self, data: dict) -> bool:
        val = data.get(self.feature, 0)
        return val {op_str} self.threshold and self.expected_direction == "up"

    def should_sell(self, data: dict) -> bool:
        val = data.get(self.feature, 0)
        return val {op_str} self.threshold and self.expected_direction == "down"

    def execute(self, data: dict) -> str:
        if self.should_buy(data): return "buy"
        if self.should_sell(data): return "sell"
        return "hold"
"""
        return code if self.validate(code) else None

    async def save_and_load(self, strategy_name: str, code: str) -> Optional[Any]:
        """Simpan strategi ke file dan load."""
        async with self._lock:
            self._backup_main()
            filepath = self.strategies_dir / f"{strategy_name}.py"
            filepath.write_text(code, encoding="utf-8")

            spec = importlib.util.spec_from_file_location(strategy_name, filepath)
            mod = importlib.util.module_from_spec(spec)
            try:
                spec.loader.exec_module(mod)
                strategy_class = getattr(mod, strategy_name, None)
                if strategy_class:
                    instance = strategy_class()
                    self.loaded_strategies[strategy_name] = instance
                    self.version += 1
                    return instance
            except Exception as e:
                log.error(f"Load strategy error: {e}")
        return None

    async def evolve_from_uhee(self, top_hypotheses: List[dict]):
        """Evolusi strategi dari hasil UHEE."""
        for hyp_dict in top_hypotheses[:3]:
            fitness = hyp_dict.get("fitness", 0)
            if fitness < 0.5:
                continue
            name = f"strategy_v{self.version}_{int(time.time())}"
            code = self.generate_from_hypothesis(hyp_dict, name)
            if code:
                instance = await self.save_and_load(name, code)
                if instance:
                    log.info(f"Strategy evolved: {name} (fitness={fitness:.3f})")

