class SmartTradePlanner:
    def __init__(self):
        self._price_history: Dict[str, deque] = defaultdict(lambda: deque(maxlen=50))
        self._vol_history: Dict[str, deque] = defaultdict(lambda: deque(maxlen=50))
        self._entry_count: Dict[str, int] = defaultdict(int)

    def update_history(self, mint: str, price: float, volume: float):
        self._price_history[mint].append(price)
        self._vol_history[mint].append(volume)

    def analyze_entry(self, mint: str, data: Dict, intel_report: Dict, market_cond: str) -> Tuple[bool, float, str]:
        prices = list(self._price_history[mint])
        volumes = list(self._vol_history[mint])
        confidence = 0.0
        reasons = []

        # RSI check
        if len(prices) >= 14:
            deltas = [prices[i+1] - prices[i] for i in range(len(prices)-1)]
            gains = sum(max(0, d) for d in deltas[-14:])
            losses = sum(max(0, -d) for d in deltas[-14:])
            rsi = 100 - (100 / (1 + gains / losses)) if losses > 0 else 100
            if rsi > 80:
                return False, 0, "RSI_overbought"
            if 30 <= rsi <= 70:
                confidence += 0.15
                reasons.append(f"RSI_ok({rsi:.0f})")

        # Volume spike
        if len(volumes) >= 3:
            spike = volumes[-1] / statistics.mean(volumes[-4:-1]) if volumes[-4:-1] else 1
            if spike >= 1.5:
                confidence += 0.2
                reasons.append(f"vol_spike({spike:.1f}x)")

        # Buy pressure
        buy_ratio = data.get("txns_h24_buys", 0) / max(1, data.get("txns_h24_buys", 0) + data.get("txns_h24_sells", 0))
        if buy_ratio > 0.6:
            confidence += 0.2
            reasons.append(f"buy_pressure({buy_ratio:.0%})")
        elif buy_ratio < 0.4:
            return False, 0, "sell_pressure"

        # Market condition
        if market_cond in ("bull", "bull_extreme"):
            confidence += 0.15
            reasons.append(f"market_{market_cond}")
        elif market_cond in ("bear_extreme",):
            return False, 0, "bear_market"

        # Smart money
        if intel_report.get("smart_money"):
            confidence += 0.15
            reasons.append("smart_money")

        if self._entry_count[mint] >= 3:
            return False, 0, "max_entries_reached"

        min_conf = 0.45
        if confidence >= min_conf:
            self._entry_count[mint] += 1
            return True, confidence, " | ".join(reasons)
        return False, 0, f"low_confidence({confidence:.2f})"

    def reset_entry_count(self, mint: str):
        self._entry_count.pop(mint, None)

