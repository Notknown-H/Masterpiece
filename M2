class AdaptiveValidator:
    def __init__(self, min_score: int = 60):
        self.min_score = min_score
        self._outcomes: deque = deque(maxlen=50)

    async def validate(self, data: Dict, intel_report: Dict, mint: str) -> Tuple[bool, int, str]:
        score = adaptive_scorer.score(data)

        liquidity = data.get("liquidity_usd", 0)
        if liquidity < 5_000:
            return False, score, "insufficient_liquidity"

        volume = data.get("volume_h24", 0)
        if volume < 1_000:
            return False, score, "insufficient_volume"

        if intel_report.get("whale_sentiment") == "bearish":
            score -= 15
        if intel_report.get("smart_money"):
            score += 10

        effective_min = self.min_score
        if len(self._outcomes) >= 10:
            recent_wins = sum(1 for o in list(self._outcomes)[-10:] if o > 0)
            win_rate = recent_wins / 10
            if win_rate < 0.4:
                effective_min = int(self.min_score * 1.1)
            elif win_rate > 0.7:
                effective_min = int(self.min_score * 0.95)

        valid = score >= effective_min
        return valid, score, f"score_{'ok' if valid else 'low'}({score})"

    def record_outcome(self, profit_pct: float):
        self._outcomes.append(profit_pct)

