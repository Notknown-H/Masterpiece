    4. Init Trinitas controllers (Claw + Manus)
    5. Start background tasks (AIW, UHEE, Tier, Daily, Watchdog)
    6. Start Telegram polling
    """
    global unified_governor, research_orchestrator

    log.info("=" * 80)
    log.info("  AL QALB QUANTUM ULTIMATE — FULLY INTEGRATED SYSTEM STARTING")
    log.info("  QND 405B + Al Qalb Economic Core + Trinitas Bridge")
    log.info("=" * 80)

    # Step 1: Initialize database
    init_db()
    log.info("✅ Database initialized")

    # Step 2: Migrate old knowledge (dari JSON lama jika ada)
    legacy_files = [
        "local_brain.json", "knowledge.json", "brain.json",
        "data/knowledge.json", "data/brain.json"
    ]
    for fpath in legacy_files:
        if os.path.exists(fpath):
            try:
                with open(fpath, "r") as f:
                    old_data = json.load(f)
