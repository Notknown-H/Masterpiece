            None, lambda: self.brain.faiss_index.search(q_emb.reshape(1, -1), k)
        )
        for dist, idx in zip(distances[0], indices[0]):
            if idx >= 0 and idx in self.brain.id_map:
                results.append((self.brain.id_map[idx], float(dist)))
        return results

