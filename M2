class ManusController:
    """Internal OpenManus controller – fully integrated subprocess handler."""

    def __init__(self):
        self.manus_path = os.getenv("OPENMANUS_PATH", "./OpenManus")
        self.python_bin = sys.executable
        self.enabled = os.getenv("MANUS_ENABLED", "false").lower() == "true"
        self.task_queue: asyncio.Queue = asyncio.Queue()
        self.active = False
        self.results: Dict[str, Any] = {}

        # Subscribe to research requests
        event_bus.subscribe("manus_research_request", self.on_research_request)

    async def start(self):
        if not self.enabled:
            log.info("ManusController disabled")
            return
        if not os.path.isdir(self.manus_path):
            log.warning(f"ManusController: path '{self.manus_path}' not found")
            return
        main_py = os.path.join(self.manus_path, "main.py")
        if not os.path.isfile(main_py):
            log.warning(f"ManusController: main.py not found in {self.manus_path}")
            return
        self.active = True
        log.info(f"ManusController: OpenManus ready at {self.manus_path}")
        asyncio.create_task(self._process_queue())

    async def _process_queue(self):
        while self.active:
            try:
                task = await asyncio.wait_for(self.task_queue.get(), timeout=5.0)
                await self._execute(task)
            except asyncio.TimeoutError:
                continue
            except Exception as e:
                log.error(f"ManusController queue error: {e}")

    async def _execute(self, task: dict):
        task_id = task.get("id", str(uuid.uuid4()))
        prompt = task.get("prompt", "")
        max_steps = task.get("max_steps", 20)

        cmd = [
            self.python_bin,
            os.path.join(self.manus_path, "main.py"),
            "--prompt", prompt,
            "--max-steps", str(max_steps)
        ]

        try:
            process = await asyncio.create_subprocess_exec(
                *cmd,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE,
                cwd=self.manus_path
            )
            stdout, stderr = await asyncio.wait_for(process.communicate(), timeout=300)
            result = {
                "success": process.returncode == 0,
                "stdout": stdout.decode('utf-8', errors='replace') if stdout else "",
                "stderr": stderr.decode('utf-8', errors='replace') if stderr else "",
                "returncode": process.returncode
            }
            self.results[task_id] = result
            log.info(f"Manus executed: success={result['success']}")
            await event_bus.publish("manus_result", {"id": task_id, "result": result})

            # Store result into brain if relevant
            if result["success"] and result["stdout"]:
                summary = result["stdout"][:1000]
                unified_brain.add_knowledge([{
                    "id": f"manus_{task_id[:8]}",
                    "topic": "manus_research",
                    "statement": summary,
                    "epistemic_type": "fact",
                }])
        except asyncio.TimeoutError:
            self.results[task_id] = {"error": "Timeout", "success": False}
        except Exception as e:
            self.results[task_id] = {"error": str(e), "success": False}

    async def send_task(self, prompt: str, max_steps: int = 20) -> str:
        if not self.active:
            return ""
        task_id = str(uuid.uuid4())
        await self.task_queue.put({
            "id": task_id,
            "prompt": prompt,
            "max_steps": max_steps,
        })
        return task_id

    async def on_research_request(self, data: dict):
        query = data.get("query", "")
        if query:
            await self.send_task(f"Perform deep research on: {query}. Return structured summary with sources.")

    async def close(self):
        self.active = False

