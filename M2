# 7. 3‑LEVEL MEMORY MANAGER (UNIFIED, THREAD‑SAFE, ASYNC‑FRIENDLY)
# =============================================================================
class ThreeLevelMemoryManager:
    """Menggabungkan NP dan Torch, menyediakan akses async via executor."""

    def __init__(self, l1_mb: int = 50, l2_mb: int = 500, ssd_dir: str = "ssd_experts"):
        self.l1 = OrderedDict()          # {expert_id: tensor}
        self.l2 = OrderedDict()
        self.l1_limit = l1_mb * 1024 * 1024
        self.l2_limit = l2_mb * 1024 * 1024
        self.ssd_dir = ssd_dir
        self.ssd_index: Dict[str, Dict] = {}
        self.l1_usage = 0
        self.l2_usage = 0
        self._lock = threading.RLock()
        os.makedirs(ssd_dir, exist_ok=True)

    # ----------- SINKRON (internal, harus dipanggil dari executor) ----------
    def _save_to_ssd(self, expert_id: str, tensor: Union[np.ndarray, torch.Tensor]) -> str:
        path = os.path.join(self.ssd_dir, f"expert_{expert_id}.qsd")
        if isinstance(tensor, np.ndarray):
            packed, scale, zp = QuantizationUtil.quantize_2bit_np(tensor)
            with open(path, 'wb') as f:
                f.write(struct.pack('I' * len(tensor.shape), *tensor.shape))
                f.write(struct.pack('ff', scale, zp))
                f.write(packed.tobytes())
        else:
            packed, scale, zp = QuantizationUtil.quantize_2bit_torch(tensor)
            torch.save({'shape': tensor.shape, 'packed': packed.cpu(),
                        'scale': scale.cpu(), 'zero_point': zp.cpu()}, path)
        info = {"path": path, "shape": tensor.shape,
                "scale": scale.item() if hasattr(scale,'item') else scale,
                "zero_point": zp.item() if hasattr(zp,'item') else zp,
                "size": os.path.getsize(path)}
        with self._lock:
            self.ssd_index[expert_id] = info
        return path

    def _load_from_ssd(self, expert_id: str) -> Optional[Union[np.ndarray, torch.Tensor]]:
        with self._lock:
            info = self.ssd_index.get(expert_id)
        if not info:
            return None
        if info['path'].endswith('.qsd'):
            with open(info['path'], 'rb') as f:
                ndim = len(info['shape'])
                _ = f.read(ndim * struct.calcsize('I'))
                scale = struct.unpack('f', f.read(4))[0]
                zp = struct.unpack('f', f.read(4))[0]
                packed = np.frombuffer(f.read(), dtype=np.uint8)
            return QuantizationUtil.dequantize_2bit_np(packed, info['shape'], scale, zp)
        else:
            data = torch.load(info['path'], map_location='cpu')
            return QuantizationUtil.dequantize_2bit_torch(
                data['packed'].to(device), info['shape'],
                data['scale'].to(device), data['zero_point'].to(device))

    def _get_expert_sync(self, expert_id: str):
        """Sinkron, gunakan hanya dari executor."""
        with self._lock:
            if expert_id in self.l1:
                tensor = self.l1.pop(expert_id)
                self.l1[expert_id] = tensor    # move to end
                return tensor
            if expert_id in self.l2:
                tensor = self.l2.pop(expert_id)
                self._promote_to_l1(expert_id, tensor)
                return tensor
        # load from SSD
        tensor = self._load_from_ssd(expert_id)
        if tensor is not None:
            self._promote_to_l1(expert_id, tensor)
        return tensor

    def _promote_to_l1(self, expert_id: str, tensor):
        size = self._tensor_size(tensor)
        with self._lock:
            while self.l1_usage + size > self.l1_limit and self.l1:
                old_id, old_tensor = self.l1.popitem(last=False)
                self.l1_usage -= self._tensor_size(old_tensor)
                self._demote_to_l2(old_id, old_tensor)
            self.l1[expert_id] = tensor
            self.l1_usage += size

    def _demote_to_l2(self, expert_id: str, tensor):
        size = self._tensor_size(tensor)
        with self._lock:
            while self.l2_usage + size > self.l2_limit and self.l2:
                old_id, old_tensor = self.l2.popitem(last=False)
                self.l2_usage -= self._tensor_size(old_tensor)
                self._save_to_ssd(old_id, old_tensor)      # SSD write
            self.l2[expert_id] = tensor
            self.l2_usage += size

    def _tensor_size(self, tensor) -> int:
        if isinstance(tensor, np.ndarray):
            return tensor.nbytes
        else:
            return tensor.element_size() * tensor.numel()

    def clear_cache(self):
        with self._lock:
            self.l1.clear()
            self.l2.clear()
            self.l1_usage = 0
            self.l2_usage = 0

    # ----------- ASYNC WRAPPER ----------
    async def get_expert(self, expert_id: str):
        loop = asyncio.get_running_loop()
        return await loop.run_in_executor(None, self._get_expert_sync, expert_id)

    async def save_expert(self, expert_id: str, tensor):
        loop = asyncio.get_running_loop()
        return await loop.run_in_executor(None, self._save_to_ssd, expert_id, tensor)

